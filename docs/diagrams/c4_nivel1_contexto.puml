@startuml c4_nivel1_contexto
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title Diagrama de Contexto - Snake Multiplayer Local (Nivel 1)

Person(jogadores, "Jogadores Locais (J1 a J4)", "Controla a cobra em 4 direcoes e navega\nentre menu, jogo e pausa.\nAte 4 jogadores no mesmo computador.\nEntrada: teclado ou joystick.")

System(snake, "Snake Multiplayer Local", "Jogo da cobrinha para ate 4 jogadores\nno mesmo computador, desenvolvido\nem Python com pygame.")

System_Ext(so, "Sistema Operacional + Pygame/SDL", "Gerencia a janela do jogo, captura\neventos de teclado e joystick\ne renderiza o jogo em 2D via SDL.")

Rel(jogadores, snake, "Enviam comandos de jogo", "teclado ou joystick")
Rel(snake, so, "Usa", "API pygame / SDL")

@enduml
